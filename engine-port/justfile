set shell := ["bash", "-lc"]

# Install local JS deps and browser binaries for this framework.
install-testing-deps:
    npm install --no-fund --no-audit
    npx playwright install chromium

# Fast smoke path with screenshot trail.
test-smoke base_url="" headless="1" debug="0":
    node scripts/testing/smoke.mjs --base-url "{{base_url}}" --headless "{{headless}}" --debug "{{debug}}"

# Full E2E path (menu + water + smoke by default).
test-e2e feature="full" base_url="" headless="1" debug="0":
    node scripts/testing/e2e.mjs --feature "{{feature}}" --base-url "{{base_url}}" --headless "{{headless}}" --debug "{{debug}}"

# Parallel story execution with isolated browser contexts.
test-parallel suite="core" workers="3" base_url="" headless="1" debug="0":
    node scripts/testing/parallel.mjs --suite "{{suite}}" --workers "{{workers}}" --base-url "{{base_url}}" --headless "{{headless}}" --debug "{{debug}}"

# Orchestrate a dev server command and a selected test target.
run-dev-and-test test_target="test-smoke" dev_cmd="node scripts/testing/serve_fixture.mjs --port 4173" base_url="http://127.0.0.1:4173":
    bash scripts/testing/run_dev_and_test.sh '{{dev_cmd}}' '{{base_url}}' '{{test_target}}'

# Headed visual debug run.
test-debug:
    node scripts/testing/smoke.mjs --debug 1
